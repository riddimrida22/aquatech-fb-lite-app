# -----------------------
# AquatechPM config
# -----------------------

# Core ports
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=fblite
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME_DB_PASSWORD@db:5432/fblite

# Auth / session
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
ALLOWED_GOOGLE_DOMAIN=aquatechpc.com
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_STRING
FRONTEND_ORIGIN=http://localhost:3000

# Dev bypass (set false for launch)
DEV_AUTH_BYPASS=false
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# Frontend API target
NEXT_PUBLIC_API_BASE=auto

# Daily timesheet reminder (Mon-Fri at local time)
TIMESHEET_REMINDER_ENABLED=false
TIMESHEET_REMINDER_HOUR_LOCAL=15
TIMESHEET_REMINDER_MINUTE_LOCAL=0
TIMESHEET_REMINDER_TIMEZONE=America/New_York

# SMTP email config (required when reminder enabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Recurring invoice runner (Mon-Fri at local time)
RECURRING_INVOICE_ENABLED=true
RECURRING_INVOICE_RUN_HOUR_LOCAL=8
RECURRING_INVOICE_RUN_MINUTE_LOCAL=5
RECURRING_INVOICE_TIMEZONE=America/New_York

# Payment links
PAYMENT_LINK_DEFAULT_EXPIRY_DAYS=14
PAYMENT_LINKS_ENABLED=false

# Plaid bank feed (start in sandbox)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US

# Gusto API (read-only employees + payrolls)
# DEPRECATED 2026-06-02: Gusto integration is abandoned. We are transitioning
#   payroll to Paychex (timing TBD). These vars and backend/app/gusto.py remain
#   only to keep parsing historical Gusto Payroll Journal CSVs already imported.
#   Leave blank; do not pursue Gusto production approval. See docs/archive/.
# Demo (default): api.gusto-demo.com — credentials issued by dev.gusto.com
# Production    : api.gusto.com — switch after Gusto approves the app for production
GUSTO_CLIENT_ID=
GUSTO_CLIENT_SECRET=
GUSTO_REDIRECT_URI=http://localhost:8000/auth/gusto/callback
GUSTO_API_BASE=https://api.gusto-demo.com
GUSTO_AUTH_BASE=https://api.gusto-demo.com
GUSTO_API_VERSION=2026-02-01

# FreshBooks API (read-only sync of clients/invoices/expenses)
FRESHBOOKS_CLIENT_ID=
FRESHBOOKS_CLIENT_SECRET=
FRESHBOOKS_REDIRECT_URI=http://localhost:8000/auth/freshbooks/callback

# FreshBooks transition inbox on local machine
FRESHBOOKS_TRANSITION_DIR=/mnt/c/Users/<your-user>/Downloads/AqtPM-Uploads

# -----------------------
# Production deployment
# -----------------------
APP_DOMAIN=app.yourdomain.com
ACME_EMAIL=ops@yourdomain.com
BACKUP_RETENTION_DAYS=14

# For production behind HTTPS reverse proxy
SESSION_HTTPS_ONLY=true
SESSION_SAME_SITE=lax
CORS_ALLOW_INTERNAL_REGEX=false
