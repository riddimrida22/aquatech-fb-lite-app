{
  "id": null,
  "uid": "aquatech-uptime-overview",
  "title": "AquatechPM Uptime Overview",
  "tags": ["aquatechpm", "sre"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Endpoint Up",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox-http\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "type": "timeseries",
      "title": "Probe Latency (s)",
      "gridPos": {"h": 9, "w": 16, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "probe_duration_seconds{job=\"blackbox-http\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Availability (%) - 24h",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 6},
      "targets": [
        {
          "expr": "100 * avg_over_time(probe_success{job=\"blackbox-http\"}[24h])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    }
  ],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"}
}
